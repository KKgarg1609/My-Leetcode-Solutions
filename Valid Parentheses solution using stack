class Solution {
public:
    bool isValid(string s) {
        vector<char> S;
        if (s.empty()) {
            return true;
        }
        if (s.size() % 2 != 0) {
            return false;
        }
        for (int i = 0; i < s.size(); i++) {
            if (s[i] == '(' || s[i] == '{' || s[i] == '[') {
                S.push_back(s[i]);
            } else if (s[i] == ')' && S.empty() || s[i] == '}' && S.empty() ||
                       s[i] == ']' && S.empty()) {
                return false;
            } else if (s[i] == ')' && S.back() == '(' ||
                       s[i] == '}' && S.back() == '{' ||
                       s[i] == ']' && S.back() == '[') {
                S.pop_back();
            } else
                return false;
        }

        if (S.empty()) {
            return true;
        } else {
            return false;
        }
    }
};
